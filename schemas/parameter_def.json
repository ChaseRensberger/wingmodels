{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wingmodels.dev/schemas/parameter_def.json",
  "title": "Parameter Definition",
  "description": "Canonical request parameter vocabulary entry.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["string", "number", "boolean", "integer", "array", "object"]
    },
    "category": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source" }
    }
  },
  "required": ["id", "name", "description", "type"],
  "additionalProperties": false,
  "$defs": {
    "source": {
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "retrieved_at": { "type": "string" }
      },
      "required": ["label", "url"],
      "additionalProperties": false
    }
  }
}
